ANTHROPIC_API_KEY=your_anthropic_api_key_here
ORCHESTRATOR_API_TOKEN=
DEV_USER_ID=dev-user
DEV_ORG_ID=dev-org
MAX_CONCURRENT_SESSIONS_PER_USER=10
MAX_CONCURRENT_SESSIONS_PER_ORG=50
MAX_SESSION_RUNTIME_SECONDS=3600
MAX_IDLE_SESSION_SECONDS=1800
MAX_MESSAGES_PER_SESSION=100
MAX_EVENTS_PER_SESSION=5000
PLATFORM_DISABLE_NEW_SESSIONS=false
GLOBAL_KILL_SWITCH=false
ORG_DISABLE_NEW_SESSIONS=
PROTECT_SESSION_UI=false
UI_TOKEN_SECRET=
UI_TOKEN_TTL_SECONDS=300

# Orchestrator
COMPUTER_USE_DB_PATH=./data/orchestrator.db
API=http://127.0.0.1:9000
WORKER_LAUNCHER=local_docker
PUBLIC_HOST=127.0.0.1
WORKER_CONNECT_HOST=127.0.0.1
WORKER_IMAGE=computer-use-demo:local
LOG_LEVEL=INFO
LOG_FORMAT=text
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://[::]:5173
CLEANUP_ORPHAN_WORKERS_ON_STARTUP=false

# Worker runtime
MODEL=claude-sonnet-4-5-20250929
TOOL_VERSION=computer_use_20250124
MAX_TOKENS=4096
API_PROVIDER=anthropic
HIDE_WARNING=false
ENABLE_STREAMLIT=false
VNC_PASSWORD=

# Container display defaults
DISPLAY_NUM=1
HEIGHT=768
WIDTH=1024

# Orchestrator timeouts
SESSION_TTL_SECONDS=300
CLEANUP_EVERY_SECONDS=30
WORKER_READY_TIMEOUT_SECONDS=25.0
WORKER_READY_POLL_SECONDS=0.5
WORKER_STATUS_POLL_SECONDS=2.0
SSE_RETRY_LIMIT=3
SSE_RETRY_INITIAL_BACKOFF_SECONDS=0.25
SSE_RETRY_MAX_BACKOFF_SECONDS=3.0

# Worker container limits
WORKER_CPU_LIMIT=1.0
WORKER_MEMORY_LIMIT=2g
WORKER_PIDS_LIMIT=512
